global:
  scrape_interval: 15s
  scrape_timeout: 1m

scrape_configs:

{% if blackbox_service | default(false) | bool %}
  - job_name: 'icmp_ping_external_vm'
    scrape_interval: 30s
    metrics_path: /probe
    params:
      module: [icmp_ping]
    static_configs:
      - targets:
          - 1.1.1.1
          - 8.8.8.8
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__address__]
        target_label: target
      - target_label: instance
        replacement: "{{ inventory_hostname }}"
      - target_label: __address__
        replacement: localhost:9115
      - target_label: device_type
        replacement: link_wan_vm
{% endif %}

  - job_name: 'vmagent_internal'
    static_configs:
      - targets:
          - 'localhost:8429'
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__address__]
        target_label: target
      - target_label: instance
        replacement: "{{ inventory_hostname }}"
      - target_label: __address__
        replacement: localhost:8429
      - target_label: job
        replacement: vmagent_internal   

{% if ansible_architecture == 'aarch64' %}
  - job_name: 'node_exporter'
    static_configs:
      - targets:
          - localhost:9100
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__address__]
        target_label: target
      - target_label: instance
        replacement: "{{ inventory_hostname }}"
      - target_label: __address__
        replacement: localhost:9100
      - target_label: job
        replacement: fw-node-exporter
{% endif %}

{% if ansible_architecture == 'x86_64' %}
  - job_name: 'node_exporter'
    static_configs:
      - targets:
          - localhost:9100
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__address__]
        target_label: target
      - target_label: instance
        replacement: "{{ inventory_hostname }}"
      - target_label: __address__
        replacement: localhost:9100
      - target_label: job
        replacement: node_exporter
{% endif %}

  - job_name: 'telegraf'
    static_configs:
      - targets: 
          - localhost:9273
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__address__]
        target_label: target
      - target_label: instance
        replacement: "{{ inventory_hostname }}"
      - target_label: __address__
        replacement: localhost:9273
      - target_label: job
        replacement: telegraf